// Схема базы данных платформы 2470
// ORM: Prisma | База: Timeweb Cloud PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// РОЛИ
// ============================================================

enum Role {
  OWNER
  ADMIN
  OPERATOR
  EDITOR
  CLIENT
}

enum ClientType {
  INDIVIDUAL
  SELF_EMPLOYED
  IP
  LLC
  AGENCY
}

enum ClientStatus {
  NEW
  ACTIVE
  REPEAT
  REGULAR
  SLEEPING
  PROBLEM
  ARCHIVED
}

enum ClientSource {
  YANDEX_MAPS
  CONTEXT_ADS
  RECOMMENDATION
  REPEAT_REQUEST
  WEBSITE
  TELEGRAM
  INSTAGRAM
  YOUTUBE
  AVITO_PROFI
  COLD_OUTREACH
  PARTNER_AGENCY
  OTHER
}

enum MaterialsStatus {
  NO_LINKS
  YANDEX_ACTIVE
  YANDEX_EXPIRED
  BACKUP_EXISTS
  NEEDS_ATTENTION
}

enum SubscriptionStatus {
  ACTIVE
  USED_UP
  CANCELLED
}

enum EventType {
  STUDIO_BOOKING
  MEETING
  STAFF_UNAVAILABILITY
  SERVICE_NOTE
  OTHER
}

enum ClientConfirmationStatus {
  NOT_REQUIRED
  PENDING
  CONFIRMED
  IGNORED
}

// Способ оплаты разовой (не по абонементу) записи в расписании — SUBSCRIPTION
// используется только заказами (Order), для ScheduleEvent оплата абонементом
// определяется через отдельную связь SubscriptionUsage, не через это поле.
enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  INVOICE
  UNPAID
  FREE
  OTHER
  SUBSCRIPTION
}

enum OrderStatus {
  LEAD
  BOOKED
  EDITING
  REVISIONS
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum OrderSource {
  MANUAL
  GOOGLE_CALENDAR
  OTHER
}

enum OrderPaymentStatus {
  NOT_SPECIFIED
  UNPAID
  PARTIALLY_PAID
  PAID
  SUBSCRIPTION
}

// ============================================================
// ПОЛЬЗОВАТЕЛИ (CMS)
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      Role     @default(OPERATOR)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  clients   Client[]     @relation("ResponsibleUser")
  notes     ClientNote[]
  auditLogs AuditLog[]

  @@map("cms_user")
}

// ============================================================
// КЛИЕНТ
// ============================================================

model Client {
  id               String        @id @default(cuid())
  name             String
  firstName        String?       @map("first_name")
  lastName         String?       @map("last_name")
  patronymic       String?
  workplace        String?
  type             ClientType    @default(INDIVIDUAL)
  status           ClientStatus  @default(NEW)
  source           ClientSource?
  customSource     String?       @map("custom_source")
  contactPerson    String?       @map("contact_person")
  phone            String?
  telegram         String?
  email            String?
  companyName      String?       @map("company_name")
  inn              String?
  kpp              String?
  ogrn             String?
  legalAddress     String?       @map("legal_address")
  documentComment  String?       @map("document_comment")
  notes            String?
  responsibleUserId String?      @map("responsible_user_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt      @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")

  responsibleUser  User?          @relation("ResponsibleUser", fields: [responsibleUserId], references: [id])
  contacts         ClientContact[]
  clientNotes      ClientNote[]
  documents        Document[]
  visits           ClientVisit[]
  scheduleEvents   ScheduleEvent[]
  subscriptions    ClientSubscription[]
  orders           Order[]

  @@map("cms_client")
}

// ============================================================
// ИСТОРИЯ ВИЗИТОВ (импорт из таблиц студии)
// ============================================================

model ClientVisit {
  id            String    @id @default(cuid())
  clientId      String    @map("client_id")
  date          DateTime?
  room          String?
  format        String?
  durationHours Float?    @map("duration_hours")
  grossAmount   Float?    @map("gross_amount")
  netAmount     Float?    @map("net_amount")
  comment       String?
  importSource  String?   @map("import_source")
  importedAt    DateTime  @default(now()) @map("imported_at")
  // Хэш исходной строки Google-таблицы (дата+зал+формат+часы+суммы+комментарий) —
  // ключ для безопасной автосинхронизации: позволяет отличить уже загруженную
  // строку от новой без риска задвоить визит при повторном запуске.
  sourceRowHash String?   @unique @map("source_row_hash")

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("cms_client_visit")
}

// ============================================================
// ДОПОЛНИТЕЛЬНЫЕ КОНТАКТЫ
// ============================================================

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  name      String?
  role      String?
  phone     String?
  telegram  String?
  email     String?
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("cms_client_contact")
}

// ============================================================
// ВНУТРЕННИЕ ЗАМЕТКИ
// ============================================================

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  authorId  String?  @map("author_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id])

  @@map("cms_client_note")
}

// ============================================================
// ЖУРНАЛ ДЕЙСТВИЙ
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user       User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@map("cms_audit_log")
}

// ============================================================
// ДОКУМЕНТЫ
// ============================================================

model Document {
  id           String   @id @default(cuid())
  clientId     String?  @map("client_id")
  type         String?
  fileName     String   @map("file_name")
  storageUrl   String   @map("storage_url")
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  client       Client?  @relation(fields: [clientId], references: [id])

  @@map("cms_document")
}

// ============================================================
// РАСПИСАНИЕ — АННОТАЦИИ К СОБЫТИЯМ GOOGLE КАЛЕНДАРЯ
// Google Calendar остаётся источником правды по названию/времени
// (сервис-аккаунт только на чтение). Здесь хранится только то, чего
// в календаре нет: зал, формат, камеры, цена, ссылки на материалы,
// статусы, привязка к клиенту.
// ============================================================

model ScheduleEvent {
  id                       String                    @id @default(cuid())
  calendarEventId          String?                   @unique @map("calendar_event_id")
  // Снэпшот для страницы Клиентов (блок неподтверждённых) — НЕ источник правды.
  // На странице Расписания эти поля всегда берутся из живого Google Calendar.
  title                    String?
  description              String?
  startAt                  DateTime?                 @map("start_at")
  endAt                    DateTime?                 @map("end_at")
  // Тип события: студийная запись / встреча / отсутствие сотрудника / служебная
  // пометка / прочее. Проверки материалов и оплаты применяются только к
  // STUDIO_BOOKING. Пока аннотации нет — тип определяется на лету по названию
  // события (classifyEventType), сюда он попадает только после первого
  // сохранения карточки (авто или вручную выбранный).
  eventType                EventType                 @default(STUDIO_BOOKING) @map("event_type")
  clientId                 String?                   @map("client_id")
  clientNameRaw            String?                   @map("client_name_raw")
  contactRaw               String?                   @map("contact_raw")
  companyRaw               String?                   @map("company_raw")
  room                     String?
  format                   String?
  camerasCount             Int?                      @map("cameras_count")
  estimatedPrice           Float?                    @map("estimated_price")
  paymentMethod            PaymentMethod?            @map("payment_method")
  notes                    String?
  yandexDiskUrl            String?                   @map("yandex_disk_url")
  yandexDiskUrlAddedAt     DateTime?                  @map("yandex_disk_url_added_at")
  yandexDiskUrlExpiresAt   DateTime?                  @map("yandex_disk_url_expires_at")
  nasBackupUrl             String?                   @map("nas_backup_url")
  materialsComment         String?                   @map("materials_comment")
  materialsStatus          MaterialsStatus           @default(NO_LINKS) @map("materials_status")
  clientConfirmationStatus ClientConfirmationStatus  @default(NOT_REQUIRED) @map("client_confirmation_status")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt      @map("updated_at")

  // Заказ (Order), из которого эта запись создана — только для записей,
  // созданных вручную через раздел "Заказы" без события Google Calendar
  // (calendarEventId в этом случае null). Записи, импортированные из живого
  // календаря, тоже могут иметь orderId — см. Order.googleEventId.
  orderId                  String?                   @unique @map("order_id")

  client                   Client?                   @relation(fields: [clientId], references: [id])
  order                    Order?                    @relation(fields: [orderId], references: [id])
  subscriptionUsage        SubscriptionUsage?

  @@index([clientId])
  @@index([clientConfirmationStatus])
  @@index([startAt])
  @@index([eventType])
  @@map("cms_schedule_event")
}

// ============================================================
// ЗАКАЗЫ (CRM-воронка): Заявка → Записан в студию → Монтаж → Правки → Готово.
// Order — карточка воронки; при заполнении даты/времени записи к ней
// привязывается ScheduleEvent (см. ScheduleEvent.orderId) — та же модель,
// что используется для записей из Google Calendar ("Booking" из ТЗ).
// Google Calendar НЕ обновляется этой моделью ни при каких условиях — только
// импорт (googleEventId) в одну сторону, платформа в календарь не пишет.
// ============================================================

model Order {
  id                String             @id @default(cuid())
  status            OrderStatus        @default(LEAD)
  source            OrderSource        @default(MANUAL)
  title             String?
  clientId          String?            @map("client_id")
  // Снэпшот контактных данных на момент создания заказа — не источник правды,
  // если клиент привязан (clientId): тогда актуальные данные берутся из Client.
  // Хранится и для непривязанных заявок, и как история для привязанных.
  clientName        String?            @map("client_name")
  clientPhone       String?            @map("client_phone")
  clientTelegram    String?            @map("client_telegram")
  clientEmail       String?            @map("client_email")
  clientType        ClientType?        @map("client_type")
  companyName       String?            @map("company_name")
  serviceType       String?            @map("service_type")
  room              String?
  plannedStartTime  DateTime?          @map("planned_start_time")
  plannedEndTime    DateTime?          @map("planned_end_time")
  durationMinutes   Int?               @map("duration_minutes")
  preliminaryAmount Float?             @map("preliminary_amount")
  paymentStatus     OrderPaymentStatus @default(NOT_SPECIFIED) @map("payment_status")
  paymentMethod     PaymentMethod?     @map("payment_method")
  comment           String?
  // Событие Google Calendar, из которого создан заказ (только source=GOOGLE_CALENDAR).
  // Используется для защиты от дублей при повторном импорте/сохранении события.
  googleEventId     String?            @unique @map("google_event_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt      @map("updated_at")
  completedAt       DateTime?          @map("completed_at")

  client            Client?            @relation(fields: [clientId], references: [id])
  scheduleEvent      ScheduleEvent?

  @@index([clientId])
  @@index([status])
  @@map("cms_order")
}

// ============================================================
// АБОНЕМЕНТЫ КЛИЕНТОВ — покупка пакета часов записи (6/10/20),
// списываемых по отдельным записям расписания (ScheduleEvent).
// Оплата абонемента (paidAmount) фиксируется один раз при покупке —
// отдельные записи, списывающие из него часы, не создают повторную выручку.
// ============================================================

model ClientSubscription {
  id           String             @id @default(cuid())
  clientId     String             @map("client_id")
  packageHours Float              @map("package_hours")
  // Часы, использованные ДО того, как эту запись начали привязывать к событиям
  // расписания (например, реконструированные из старых заметок в Google-таблице,
  // где известен только текущий остаток, а не список сессий). Реальный расход
  // считается как openingUsedHours + сумма SubscriptionUsage.usedHours — так
  // packageHours всегда остаётся исходным размером пакета, а не "тем, что осталось".
  openingUsedHours Float          @default(0) @map("opening_used_hours")
  paidAmount   Float?             @map("paid_amount")
  purchasedAt  DateTime           @default(now()) @map("purchased_at")
  status       SubscriptionStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt      @map("updated_at")

  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  usages       SubscriptionUsage[]

  @@index([clientId])
  @@index([status])
  @@map("cms_client_subscription")
}

// Списание часов по одной записи расписания. У события может быть максимум
// одно списание (@@unique) — при смене абонемента/пересохранении старая
// строка заменяется, а не накапливается.
model SubscriptionUsage {
  id              String   @id @default(cuid())
  subscriptionId  String   @map("subscription_id")
  scheduleEventId String   @unique @map("schedule_event_id")
  usedHours       Float    @map("used_hours")
  usedAt          DateTime @default(now()) @map("used_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  subscription    ClientSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  scheduleEvent   ScheduleEvent      @relation(fields: [scheduleEventId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("cms_subscription_usage")
}

// ============================================================
// РАСХОДЫ СТУДИИ (импорт из Google-таблицы "Расходы" + ручное добавление в будущем)
// ============================================================

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  expenses  Expense[]

  @@map("cms_expense_category")
}

// Один расход/обязательство. plannedAmount — полная стоимость покупки/услуги,
// actualAmount — сколько из неё реально оплачено на сегодня (может расти со
// временем по мере частичных оплат одного и того же обязательства). Остаток,
// процент оплаты и статус план/факт считаются на лету в actions-слое, а не
// хранятся здесь — так же, как остаток часов абонемента не хранится в БД,
// чтобы не рассинхронизироваться при пересчёте.
model Expense {
  id             String           @id @default(cuid())
  externalSource String           @default("google_sheets") @map("external_source")
  // Стабильный идентификатор строки таблицы — хэш от даты+названия+категории+
  // плановой суммы (полей, которые НЕ меняются при частичной оплате). Позволяет
  // при повторной синхронизации ОБНОВИТЬ существующий расход (если увеличилась
  // фактическая оплата), а не создать дубликат. Ручные расходы (без импорта) —
  // без внешнего идентификатора.
  externalId     String?          @unique @map("external_id")
  date           DateTime?
  title          String
  categoryId     String?          @map("category_id")
  plannedAmount  Float?           @map("planned_amount")
  actualAmount   Float?           @map("actual_amount")
  // Статус как он записан в таблице ("Получен"/"Заказан" и т.д.) — хранится как
  // свободный текст, без строгого enum, потому что реальные данные содержат
  // нестандартные значения (например, для позиций-пожеланий на оборудование).
  rawStatus      String?          @map("raw_status")
  orderedBy      String?          @map("ordered_by")
  paidBy         String?          @map("paid_by")
  receivedBy     String?          @map("received_by")
  comment        String?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt      @map("updated_at")

  category       ExpenseCategory? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([date])
  @@map("cms_expense")
}
