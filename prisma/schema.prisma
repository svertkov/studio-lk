// Схема базы данных платформы 2470
// ORM: Prisma | База: Timeweb Cloud PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// РОЛИ
// ============================================================

enum Role {
  OWNER
  ADMIN
  OPERATOR
  EDITOR
  CLIENT
}

enum ClientType {
  INDIVIDUAL
  SELF_EMPLOYED
  IP
  LLC
  AGENCY
}

enum ClientStatus {
  NEW
  ACTIVE
  REPEAT
  REGULAR
  SLEEPING
  PROBLEM
  ARCHIVED
}

enum ClientSource {
  YANDEX_MAPS
  CONTEXT_ADS
  RECOMMENDATION
  REPEAT_REQUEST
  WEBSITE
  TELEGRAM
  INSTAGRAM
  YOUTUBE
  AVITO_PROFI
  COLD_OUTREACH
  PARTNER_AGENCY
  OTHER
}

enum MaterialsStatus {
  NO_LINKS
  YANDEX_ACTIVE
  YANDEX_EXPIRED
  BACKUP_EXISTS
  NEEDS_ATTENTION
}

enum SubscriptionStatus {
  ACTIVE
  USED_UP
  CANCELLED
}

enum EventType {
  STUDIO_BOOKING
  MEETING
  STAFF_UNAVAILABILITY
  SERVICE_NOTE
  OTHER
}

enum ClientConfirmationStatus {
  NOT_REQUIRED
  PENDING
  CONFIRMED
  IGNORED
}

// Способ оплаты разовой (не по абонементу) записи в расписании — SUBSCRIPTION
// используется только заказами (Order), для ScheduleEvent оплата абонементом
// определяется через отдельную связь SubscriptionUsage, не через это поле.
enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  INVOICE
  UNPAID
  FREE
  OTHER
  SUBSCRIPTION
}

enum OrderStatus {
  LEAD
  BOOKED
  EDITING
  REVISIONS
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum OrderSource {
  MANUAL
  GOOGLE_CALENDAR
  TELEGRAM_BOT
  OTHER
}

enum OrderPaymentStatus {
  NOT_SPECIFIED
  UNPAID
  PARTIALLY_PAID
  PAID
  SUBSCRIPTION
}

enum TelegramChatType {
  PRIVATE
  GROUP
  SUPERGROUP
}

// consent_required/consent_given/waiting_manager — этапы юридического
// consent-first флоу до того, как в диалог включается администратор.
// ORDER_CREATED — было CONVERTED_TO_ORDER: переименовано, т.к. в этом
// проекте создание заказа — прямая одношаговая операция (createOrder),
// без промежуточного черновика, так что отдельный "draft"-статус не нужен.
enum TelegramConversationStatus {
  NEW
  CONSENT_REQUIRED
  CONSENT_GIVEN
  WAITING_MANAGER
  IN_PROGRESS
  ORDER_CREATED
  ARCHIVED
  CONSENT_REVOKED
}

enum TelegramMessageDirection {
  INBOUND
  OUTBOUND
}

// Кто фактически является автором сообщения — заменяет прежний
// TelegramSenderRole (CLIENT/STUDIO/UNKNOWN, был нужен только для будущих
// групповых чатов). Теперь нужен для ЛЮБОГО сообщения, включая личные
// диалоги: разграничивает автоматические сообщения бота (запрос согласия,
// фраза про менеджера) от реальных сообщений администратора.
enum TelegramSenderType {
  CLIENT
  ADMIN
  BOT
  SYSTEM
}

enum TelegramConsentStatus {
  NONE
  GIVEN
  REVOKED
}

// PHOTO/DOCUMENT/VOICE/VIDEO/STICKER добавятся в Этапе B вместе с
// TelegramMessageAttachment — пока в БД только то, что реально используется.
enum TelegramMessageType {
  TEXT
  SYSTEM
  PHOTO
  DOCUMENT
  VOICE
  VIDEO
  STICKER
}

enum TelegramMessageStatus {
  RECEIVED
  PENDING
  SENT
  FAILED
}

// ============================================================
// ПОЛЬЗОВАТЕЛИ (CMS)
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      Role     @default(OPERATOR)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  clients   Client[]     @relation("ResponsibleUser")
  notes     ClientNote[]
  auditLogs AuditLog[]
  assignedTelegramConversations TelegramConversation[] @relation("AssignedAdmin")
  sentTelegramMessages          TelegramMessage[]
  telegramInternalNotes         TelegramInternalNote[]

  @@map("cms_user")
}

// ============================================================
// КЛИЕНТ
// ============================================================

model Client {
  id               String        @id @default(cuid())
  name             String
  firstName        String?       @map("first_name")
  lastName         String?       @map("last_name")
  patronymic       String?
  workplace        String?
  type             ClientType    @default(INDIVIDUAL)
  status           ClientStatus  @default(NEW)
  source           ClientSource?
  customSource     String?       @map("custom_source")
  contactPerson    String?       @map("contact_person")
  phone            String?
  telegram         String?
  email            String?
  companyName      String?       @map("company_name")
  inn              String?
  kpp              String?
  ogrn             String?
  legalAddress     String?       @map("legal_address")
  documentComment  String?       @map("document_comment")
  notes            String?
  responsibleUserId String?      @map("responsible_user_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt      @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")

  responsibleUser  User?          @relation("ResponsibleUser", fields: [responsibleUserId], references: [id])
  contacts         ClientContact[]
  clientNotes      ClientNote[]
  documents        Document[]
  visits           ClientVisit[]
  scheduleEvents   ScheduleEvent[]
  subscriptions    ClientSubscription[]
  orders           Order[]
  telegramConversations TelegramConversation[]

  @@map("cms_client")
}

// ============================================================
// ИСТОРИЯ ВИЗИТОВ (импорт из таблиц студии)
// ============================================================

model ClientVisit {
  id            String    @id @default(cuid())
  clientId      String    @map("client_id")
  date          DateTime?
  room          String?
  format        String?
  durationHours Float?    @map("duration_hours")
  grossAmount   Float?    @map("gross_amount")
  netAmount     Float?    @map("net_amount")
  comment       String?
  importSource  String?   @map("import_source")
  importedAt    DateTime  @default(now()) @map("imported_at")
  // Хэш исходной строки Google-таблицы (дата+зал+формат+часы+суммы+комментарий) —
  // ключ для безопасной автосинхронизации: позволяет отличить уже загруженную
  // строку от новой без риска задвоить визит при повторном запуске.
  sourceRowHash String?   @unique @map("source_row_hash")

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("cms_client_visit")
}

// ============================================================
// ДОПОЛНИТЕЛЬНЫЕ КОНТАКТЫ
// ============================================================

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  name      String?
  role      String?
  phone     String?
  telegram  String?
  email     String?
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("cms_client_contact")
}

// ============================================================
// ВНУТРЕННИЕ ЗАМЕТКИ
// ============================================================

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  authorId  String?  @map("author_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id])

  @@map("cms_client_note")
}

// ============================================================
// ЖУРНАЛ ДЕЙСТВИЙ
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user       User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@map("cms_audit_log")
}

// ============================================================
// ДОКУМЕНТЫ
// ============================================================

model Document {
  id           String   @id @default(cuid())
  clientId     String?  @map("client_id")
  type         String?
  fileName     String   @map("file_name")
  storageUrl   String   @map("storage_url")
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  client       Client?  @relation(fields: [clientId], references: [id])

  @@map("cms_document")
}

// ============================================================
// РАСПИСАНИЕ — АННОТАЦИИ К СОБЫТИЯМ GOOGLE КАЛЕНДАРЯ
// Google Calendar остаётся источником правды по названию/времени
// (сервис-аккаунт только на чтение). Здесь хранится только то, чего
// в календаре нет: зал, формат, камеры, цена, ссылки на материалы,
// статусы, привязка к клиенту.
// ============================================================

model ScheduleEvent {
  id                       String                    @id @default(cuid())
  calendarEventId          String?                   @unique @map("calendar_event_id")
  // Снэпшот для страницы Клиентов (блок неподтверждённых) — НЕ источник правды.
  // На странице Расписания эти поля всегда берутся из живого Google Calendar.
  title                    String?
  description              String?
  startAt                  DateTime?                 @map("start_at")
  endAt                    DateTime?                 @map("end_at")
  // Тип события: студийная запись / встреча / отсутствие сотрудника / служебная
  // пометка / прочее. Проверки материалов и оплаты применяются только к
  // STUDIO_BOOKING. Пока аннотации нет — тип определяется на лету по названию
  // события (classifyEventType), сюда он попадает только после первого
  // сохранения карточки (авто или вручную выбранный).
  eventType                EventType                 @default(STUDIO_BOOKING) @map("event_type")
  clientId                 String?                   @map("client_id")
  clientNameRaw            String?                   @map("client_name_raw")
  contactRaw               String?                   @map("contact_raw")
  companyRaw               String?                   @map("company_raw")
  room                     String?
  format                   String?
  camerasCount             Int?                      @map("cameras_count")
  estimatedPrice           Float?                    @map("estimated_price")
  paymentMethod            PaymentMethod?            @map("payment_method")
  notes                    String?
  yandexDiskUrl            String?                   @map("yandex_disk_url")
  yandexDiskUrlAddedAt     DateTime?                  @map("yandex_disk_url_added_at")
  yandexDiskUrlExpiresAt   DateTime?                  @map("yandex_disk_url_expires_at")
  nasBackupUrl             String?                   @map("nas_backup_url")
  materialsComment         String?                   @map("materials_comment")
  materialsStatus          MaterialsStatus           @default(NO_LINKS) @map("materials_status")
  clientConfirmationStatus ClientConfirmationStatus  @default(NOT_REQUIRED) @map("client_confirmation_status")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt      @map("updated_at")

  // Заказ (Order), из которого эта запись создана — только для записей,
  // созданных вручную через раздел "Заказы" без события Google Calendar
  // (calendarEventId в этом случае null). Записи, импортированные из живого
  // календаря, тоже могут иметь orderId — см. Order.googleEventId.
  orderId                  String?                   @unique @map("order_id")

  client                   Client?                   @relation(fields: [clientId], references: [id])
  order                    Order?                    @relation(fields: [orderId], references: [id])
  subscriptionUsage        SubscriptionUsage?

  @@index([clientId])
  @@index([clientConfirmationStatus])
  @@index([startAt])
  @@index([eventType])
  @@map("cms_schedule_event")
}

// ============================================================
// ЗАКАЗЫ (CRM-воронка): Заявка → Записан в студию → Монтаж → Правки → Готово.
// Order — карточка воронки; при заполнении даты/времени записи к ней
// привязывается ScheduleEvent (см. ScheduleEvent.orderId) — та же модель,
// что используется для записей из Google Calendar ("Booking" из ТЗ).
// Google Calendar НЕ обновляется этой моделью ни при каких условиях — только
// импорт (googleEventId) в одну сторону, платформа в календарь не пишет.
// ============================================================

model Order {
  id                String             @id @default(cuid())
  status            OrderStatus        @default(LEAD)
  source            OrderSource        @default(MANUAL)
  title             String?
  clientId          String?            @map("client_id")
  // Снэпшот контактных данных на момент создания заказа — не источник правды,
  // если клиент привязан (clientId): тогда актуальные данные берутся из Client.
  // Хранится и для непривязанных заявок, и как история для привязанных.
  clientName        String?            @map("client_name")
  clientPhone       String?            @map("client_phone")
  clientTelegram    String?            @map("client_telegram")
  clientEmail       String?            @map("client_email")
  clientType        ClientType?        @map("client_type")
  companyName       String?            @map("company_name")
  serviceType       String?            @map("service_type")
  room              String?
  plannedStartTime  DateTime?          @map("planned_start_time")
  plannedEndTime    DateTime?          @map("planned_end_time")
  durationMinutes   Int?               @map("duration_minutes")
  preliminaryAmount Float?             @map("preliminary_amount")
  paymentStatus     OrderPaymentStatus @default(NOT_SPECIFIED) @map("payment_status")
  paymentMethod     PaymentMethod?     @map("payment_method")
  comment           String?
  // Событие Google Calendar, из которого создан заказ (только source=GOOGLE_CALENDAR).
  // Используется для защиты от дублей при повторном импорте/сохранении события.
  googleEventId     String?            @unique @map("google_event_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt      @map("updated_at")
  completedAt       DateTime?          @map("completed_at")
  // Момент последней смены status (не путать с updatedAt — тот меняется при
  // любом редактировании заказа). Используется для сортировки карточек внутри
  // колонок канбана "по недавности изменения статуса". Обновляется явно в
  // updateOrderStatus/updateOrder — см. src/lib/actions/orders.ts.
  statusUpdatedAt   DateTime           @default(now()) @map("status_updated_at")
  // Telegram-диалог, из переписки которого создан заказ (кнопка "Создать
  // заказ из переписки") — тот же принцип, что и googleEventId выше: поле,
  // отслеживающее источник, живёт на Order, а не на самом источнике.
  telegramConversationId String?       @unique @map("telegram_conversation_id")

  client            Client?            @relation(fields: [clientId], references: [id])
  scheduleEvent      ScheduleEvent?
  telegramConversation TelegramConversation? @relation(fields: [telegramConversationId], references: [id])

  @@index([clientId])
  @@index([status])
  @@map("cms_order")
}

// ============================================================
// TELEGRAM — входящие заявки клиентов через Telegram-бота студии.
// MVP: только личные диалоги (chatType = PRIVATE). Групповые рабочие чаты
// (chatType GROUP/SUPERGROUP) поддержаны на уровне схемы заранее, но логика
// их чтения/различения клиент-vs-сотрудник добавится отдельным этапом позже.
// ============================================================

model TelegramConversation {
  id               String                     @id @default(cuid())
  // Строка, а не Int: chat_id супергрупп у Telegram выходит за пределы
  // диапазона обычного 32-битного целого.
  telegramChatId   String                     @unique @map("telegram_chat_id")
  chatType         TelegramChatType           @map("chat_type")
  telegramUserId   String?                    @map("telegram_user_id")   // только для private
  telegramUsername String?                    @map("telegram_username") // только для private
  groupTitle       String?                    @map("group_title")       // только для group/supergroup, не используется в MVP
  // Имя/фамилия из профиля Telegram — подсказка для сопоставления с Client,
  // не источник правды (в отличие от Client.name после ручной привязки).
  clientNameGuess  String?                    @map("client_name_guess")
  // Раздельные first_name/last_name из Telegram (в отличие от clientNameGuess,
  // который их сразу склеивает) — нужны, чтобы форма создания клиента могла
  // предзаполнить поля "Имя"/"Фамилия" по отдельности, а не одной строкой.
  // Заполняются только при первом сообщении (как и clientNameGuess), не
  // обновляются на каждое новое сообщение.
  telegramFirstName String?                   @map("telegram_first_name")
  telegramLastName  String?                   @map("telegram_last_name")
  phone            String?                                              // если клиент сам написал номер в чат
  linkedClientId   String?                    @map("linked_client_id")
  status           TelegramConversationStatus @default(NEW)
  lastMessageAt    DateTime?                  @map("last_message_at")
  createdAt        DateTime @default(now())   @map("created_at")
  updatedAt        DateTime @updatedAt        @map("updated_at")

  // ---- Consent-first (обязательно до подключения администратора) ----
  consentStatus         TelegramConsentStatus @default(NONE) @map("consent_status")
  // Момент отправки запроса согласия для consentRequestVersion — чтобы не
  // слать его повторно на каждое новое сообщение клиента.
  consentRequestSentAt   DateTime?            @map("consent_request_sent_at")
  consentRequestVersion  String?              @map("consent_request_version")
  // Telegram message_id сообщения с кнопкой «Согласиться» — нужен, чтобы
  // после нажатия убрать inline-кнопку из ЭТОГО конкретного сообщения через
  // editMessageReplyMarkup (иначе кнопка в Telegram-клиенте у клиента
  // остаётся кликабельной и после согласия).
  consentRequestMessageId String?             @map("consent_request_message_id")

  // ---- Рабочие поля инбокса ----
  assignedAdminId  String?   @map("assigned_admin_id") // информационная метка "кто ведёт", не ограничение видимости
  unreadCount      Int       @default(0) @map("unread_count")
  isPinned         Boolean   @default(false) @map("is_pinned")
  archivedAt       DateTime? @map("archived_at")
  // Первое сообщение клиента — подсказка для предзаполнения комментария заказа.
  firstMessageText String?   @map("first_message_text")

  linkedClient  Client?                @relation(fields: [linkedClientId], references: [id])
  assignedAdmin User?                  @relation("AssignedAdmin", fields: [assignedAdminId], references: [id])
  messages      TelegramMessage[]
  consents      TelegramConsent[]
  internalNotes TelegramInternalNote[]
  order         Order? // обратная связь от Order.telegramConversationId

  @@index([linkedClientId])
  @@index([status])
  @@index([assignedAdminId])
  @@map("cms_telegram_conversation")
}

model TelegramMessage {
  id                String   @id @default(cuid())
  conversationId    String   @map("conversation_id")
  // update_id — для идемпотентности на уровне всего update (в т.ч.
  // callback_query, у которого нет message_id в привычном смысле).
  telegramUpdateId  String?  @map("telegram_update_id")
  // message_id у Telegram уникален только В РАМКАХ чата, не глобально —
  // поэтому дедуп ниже строится по паре (conversationId, telegramMessageId).
  telegramMessageId String   @map("telegram_message_id")
  direction         TelegramMessageDirection
  // Кто фактически автор — клиент / администратор / бот (авто-сообщения
  // согласия) / системное событие. senderTelegramId/Username/Name заполнены
  // только когда senderType = CLIENT.
  // Дефолт CLIENT безопасен для миграции: все существующие строки на момент
  // добавления этого поля — реальные входящие сообщения от клиента.
  senderType        TelegramSenderType @default(CLIENT) @map("sender_type")
  senderAdminId     String?  @map("sender_admin_id") // если senderType = ADMIN
  senderTelegramId  String?  @map("sender_telegram_id")
  senderUsername    String?  @map("sender_username")
  senderName        String?  @map("sender_name")
  text              String?
  messageType       TelegramMessageType   @default(TEXT) @map("message_type")
  status            TelegramMessageStatus @default(RECEIVED)
  errorMessage      String?  @map("error_message")
  sentAt            DateTime? @map("sent_at")
  rawPayload        Json     @map("raw_payload")
  createdAt         DateTime @default(now()) @map("created_at")

  conversation      TelegramConversation @relation(fields: [conversationId], references: [id])
  senderAdmin       User?                @relation(fields: [senderAdminId], references: [id])
  attachment        TelegramMessageAttachment?

  // Защита от дублей при повторной доставке update от Telegram.
  @@unique([conversationId, telegramMessageId])
  @@index([conversationId])
  @@map("cms_telegram_message")
}

// Файл не хранится у нас — только telegramFileId, сам файл при каждом
// просмотре запрашивается у Telegram заново через getFile и проксируется
// через src/app/api/telegram/file/[attachmentId]/route.ts (в проекте нет
// S3/Object Storage, решение принято сознательно, см. память проекта).
// 1:1 с TelegramMessage — Telegram-альбомы (несколько фото одним сообщением)
// вне MVP.
model TelegramMessageAttachment {
  id                   String   @id @default(cuid())
  messageId            String   @unique @map("message_id")
  telegramFileId       String   @map("telegram_file_id")
  telegramFileUniqueId String?  @map("telegram_file_unique_id")
  fileName             String?  @map("file_name")
  mimeType             String?  @map("mime_type")
  fileSize             Int?     @map("file_size")
  duration             Int?     // voice/video, секунды
  width                Int?
  height               Int?
  // Статичный стикер (обычный webp) рендерится картинкой; анимированный
  // (tgs/webm) — просто плашкой в UI, без Lottie/webm-плеера.
  isAnimatedSticker    Boolean  @default(false) @map("is_animated_sticker")
  createdAt            DateTime @default(now()) @map("created_at")

  message TelegramMessage @relation(fields: [messageId], references: [id])

  @@map("cms_telegram_message_attachment")
}

// Факт согласия/отзыва — отдельная таблица (не просто поле на диалоге),
// т.к. согласие юридически значимо и должно быть неизменяемой записью:
// conversation.consentStatus — это "текущее состояние", а TelegramConsent —
// история того, когда и на какой именно текст согласия клиент нажал.
model TelegramConsent {
  id                String    @id @default(cuid())
  conversationId    String    @map("conversation_id")
  telegramUserId    String?   @map("telegram_user_id")
  telegramChatId    String    @map("telegram_chat_id")
  username          String?
  displayName       String?   @map("display_name")
  consentVersion    String    @map("consent_version")
  consentText       String    @map("consent_text")
  policyUrl         String?   @map("policy_url")
  // 'given' | 'revoked' — обычная строка, не enum: новая версия текста
  // согласия не должна требовать миграции типа.
  status            String
  givenAt           DateTime? @map("given_at")
  revokedAt         DateTime? @map("revoked_at")
  source            String    @default("telegram_bot")
  telegramMessageId String?   @map("telegram_message_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt      @map("updated_at")

  conversation TelegramConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@map("cms_telegram_consent")
}

// Внутренние заметки по диалогу — видны только сотрудникам, никогда не
// уходят клиенту (в отличие от TelegramMessage, которая всегда про переписку).
model TelegramInternalNote {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  authorUserId   String   @map("author_user_id")
  text           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  conversation TelegramConversation @relation(fields: [conversationId], references: [id])
  author       User                 @relation(fields: [authorUserId], references: [id])

  @@index([conversationId])
  @@map("cms_telegram_internal_note")
}

// Единственная строка-синглтон настроек модуля (id всегда "singleton") —
// одна конфигурация на всё приложение, не per-user. Токен бота НЕ хранится
// здесь — только в TELEGRAM_BOT_TOKEN (env), чтобы никогда не попасть на
// фронтенд даже случайно через сериализацию этой модели.
model TelegramSettings {
  id                               String   @id @default("singleton")
  privacyPolicyUrl                 String?  @map("privacy_policy_url")
  consentRequired                  Boolean  @default(true) @map("consent_required")
  consentText                      String   @map("consent_text")
  consentVersion                   String   @default("v1") @map("consent_version")
  managerHandoffMessage            String   @default("Спасибо! Согласие получено. Администратор скоро подключится к диалогу.") @map("manager_handoff_message")
  dataRetentionMode                String   @default("archive_forever") @map("data_retention_mode")
  dataRetentionDays                Int?     @map("data_retention_days")
  archiveWarningThresholdMessages  Int      @default(5000) @map("archive_warning_threshold_messages")
  archiveWarningThresholdStorageMb Int      @default(1000) @map("archive_warning_threshold_storage_mb")
  // Используется начиная с Этапа B (вложения) — задел на будущее, значение
  // по умолчанию пустое, ни на что не влияет до появления вложений.
  allowedAttachmentTypes           Json     @default("[]") @map("allowed_attachment_types")
  maxAttachmentSizeMb              Int      @default(20) @map("max_attachment_size_mb")
  updatedAt                        DateTime @updatedAt @map("updated_at")

  @@map("cms_telegram_settings")
}

// ============================================================
// АБОНЕМЕНТЫ КЛИЕНТОВ — покупка пакета часов записи (6/10/20),
// списываемых по отдельным записям расписания (ScheduleEvent).
// Оплата абонемента (paidAmount) фиксируется один раз при покупке —
// отдельные записи, списывающие из него часы, не создают повторную выручку.
// ============================================================

model ClientSubscription {
  id           String             @id @default(cuid())
  clientId     String             @map("client_id")
  packageHours Float              @map("package_hours")
  // Часы, использованные ДО того, как эту запись начали привязывать к событиям
  // расписания (например, реконструированные из старых заметок в Google-таблице,
  // где известен только текущий остаток, а не список сессий). Реальный расход
  // считается как openingUsedHours + сумма SubscriptionUsage.usedHours — так
  // packageHours всегда остаётся исходным размером пакета, а не "тем, что осталось".
  openingUsedHours Float          @default(0) @map("opening_used_hours")
  paidAmount   Float?             @map("paid_amount")
  purchasedAt  DateTime           @default(now()) @map("purchased_at")
  status       SubscriptionStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt      @map("updated_at")

  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  usages       SubscriptionUsage[]

  @@index([clientId])
  @@index([status])
  @@map("cms_client_subscription")
}

// Списание часов по одной записи расписания. У события может быть максимум
// одно списание (@@unique) — при смене абонемента/пересохранении старая
// строка заменяется, а не накапливается.
model SubscriptionUsage {
  id              String   @id @default(cuid())
  subscriptionId  String   @map("subscription_id")
  scheduleEventId String   @unique @map("schedule_event_id")
  usedHours       Float    @map("used_hours")
  usedAt          DateTime @default(now()) @map("used_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  subscription    ClientSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  scheduleEvent   ScheduleEvent      @relation(fields: [scheduleEventId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("cms_subscription_usage")
}

// ============================================================
// РАСХОДЫ СТУДИИ (импорт из Google-таблицы "Расходы" + ручное добавление в будущем)
// ============================================================

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  expenses  Expense[]

  @@map("cms_expense_category")
}

// Один расход/обязательство. plannedAmount — полная стоимость покупки/услуги,
// actualAmount — сколько из неё реально оплачено на сегодня (может расти со
// временем по мере частичных оплат одного и того же обязательства). Остаток,
// процент оплаты и статус план/факт считаются на лету в actions-слое, а не
// хранятся здесь — так же, как остаток часов абонемента не хранится в БД,
// чтобы не рассинхронизироваться при пересчёте.
model Expense {
  id             String           @id @default(cuid())
  externalSource String           @default("google_sheets") @map("external_source")
  // Стабильный идентификатор строки таблицы — хэш от даты+названия+категории+
  // плановой суммы (полей, которые НЕ меняются при частичной оплате). Позволяет
  // при повторной синхронизации ОБНОВИТЬ существующий расход (если увеличилась
  // фактическая оплата), а не создать дубликат. Ручные расходы (без импорта) —
  // без внешнего идентификатора.
  externalId     String?          @unique @map("external_id")
  date           DateTime?
  title          String
  categoryId     String?          @map("category_id")
  plannedAmount  Float?           @map("planned_amount")
  actualAmount   Float?           @map("actual_amount")
  // Статус как он записан в таблице ("Получен"/"Заказан" и т.д.) — хранится как
  // свободный текст, без строгого enum, потому что реальные данные содержат
  // нестандартные значения (например, для позиций-пожеланий на оборудование).
  rawStatus      String?          @map("raw_status")
  orderedBy      String?          @map("ordered_by")
  paidBy         String?          @map("paid_by")
  receivedBy     String?          @map("received_by")
  comment        String?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt      @map("updated_at")

  category       ExpenseCategory? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([date])
  @@map("cms_expense")
}
