// Схема базы данных платформы 2470
// ORM: Prisma | База: Timeweb Cloud PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// РОЛИ
// ============================================================

enum Role {
  OWNER
  ADMIN
  OPERATOR
  EDITOR
  CLIENT
}

enum ClientType {
  INDIVIDUAL
  SELF_EMPLOYED
  IP
  LLC
  AGENCY
}

// Договорное состояние клиента (реестр документов, не файловое хранилище —
// см. AGENTS.md "Реестр документов"). ACTIVE не гарантирует существование
// Document type=CONTRACT физически (администратор мог выставить его вручную
// до создания записи договора) — getActiveContractForClient (document-model.ts)
// это read-side отображение, а не единственный источник строгой валидации.
enum ClientContractState {
  ACTIVE
  PREPARING
  NO_CONTRACT
  ARCHIVED
  UNSPECIFIED
}

enum ClientStatus {
  NEW
  ACTIVE
  REPEAT
  REGULAR
  SLEEPING
  PROBLEM
  ARCHIVED
}

enum ClientSource {
  YANDEX_MAPS
  CONTEXT_ADS
  RECOMMENDATION
  REPEAT_REQUEST
  WEBSITE
  TELEGRAM
  INSTAGRAM
  YOUTUBE
  AVITO_PROFI
  COLD_OUTREACH
  PARTNER_AGENCY
  OTHER
}

enum MaterialsStatus {
  NO_LINKS
  YANDEX_ACTIVE
  YANDEX_EXPIRED
  BACKUP_EXISTS
  NEEDS_ATTENTION
}

enum SubscriptionStatus {
  ACTIVE
  USED_UP
  CANCELLED
  REFUNDED
}

enum EventType {
  STUDIO_BOOKING
  MEETING
  STAFF_UNAVAILABILITY
  SERVICE_NOTE
  OTHER
}

enum ClientConfirmationStatus {
  NOT_REQUIRED
  PENDING
  CONFIRMED
  IGNORED
}

// Способ оплаты разовой (не по абонементу) записи в расписании — SUBSCRIPTION
// используется только заказами (Order), для ScheduleEvent оплата абонементом
// определяется через отдельную связь SubscriptionUsage, не через это поле.
enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  INVOICE
  UNPAID
  FREE
  OTHER
  SUBSCRIPTION
}

enum OrderStatus {
  LEAD
  BOOKED
  EDITING
  REVISIONS
  COMPLETED
  CANCELLED
  ARCHIVED
}

// Почему заказ попал в архив (см. Order.isArchived) — не путать с самим
// OrderStatus.ARCHIVED (тот статус существовал и раньше, но никогда никому не
// присваивается: архивация в этой фиче — отдельный boolean-оверлей поверх
// финального статуса COMPLETED/CANCELLED, а не смена статуса на третий).
enum ArchiveReason {
  COMPLETED
  REJECTED
}

// Структурированная пометка акции — заменяет прежний подход "вставить текст
// акции прямо в комментарий" (см. src/lib/promotion-model.ts). Единственное
// значение пока — скидка 20% на первый визит; enum, а не boolean, потому что
// на платформе позже могут появиться другие акции.
enum OrderPromotionType {
  FIRST_VISIT_20
}

enum OrderSource {
  MANUAL
  GOOGLE_CALENDAR
  TELEGRAM_BOT
  OTHER
}

enum OrderPaymentStatus {
  NOT_SPECIFIED
  UNPAID
  PARTIALLY_PAID
  PAID
  SUBSCRIPTION
}

// Какой состав документов нужен этой работе — см. Order.documentFlowType.
enum DocumentFlowType {
  NOT_REQUIRED
  INVOICE_ONLY
  INVOICE_AND_ACT
  CONTRACT_INVOICE_ACT
  UNKNOWN
}

enum TelegramChatType {
  PRIVATE
  GROUP
  SUPERGROUP
}

// consent_required/consent_given/waiting_manager — этапы юридического
// consent-first флоу до того, как в диалог включается администратор.
// ORDER_CREATED — было CONVERTED_TO_ORDER: переименовано, т.к. в этом
// проекте создание заказа — прямая одношаговая операция (createOrder),
// без промежуточного черновика, так что отдельный "draft"-статус не нужен.
enum TelegramConversationStatus {
  NEW
  CONSENT_REQUIRED
  CONSENT_GIVEN
  WAITING_MANAGER
  IN_PROGRESS
  ORDER_CREATED
  ARCHIVED
  CONSENT_REVOKED
}

enum TelegramMessageDirection {
  INBOUND
  OUTBOUND
}

// Кто фактически является автором сообщения — заменяет прежний
// TelegramSenderRole (CLIENT/STUDIO/UNKNOWN, был нужен только для будущих
// групповых чатов). Теперь нужен для ЛЮБОГО сообщения, включая личные
// диалоги: разграничивает автоматические сообщения бота (запрос согласия,
// фраза про менеджера) от реальных сообщений администратора.
enum TelegramSenderType {
  CLIENT
  ADMIN
  BOT
  SYSTEM
}

enum TelegramConsentStatus {
  NONE
  GIVEN
  REVOKED
}

// PHOTO/DOCUMENT/VOICE/VIDEO/STICKER добавятся в Этапе B вместе с
// TelegramMessageAttachment — пока в БД только то, что реально используется.
enum TelegramMessageType {
  TEXT
  SYSTEM
  PHOTO
  DOCUMENT
  VOICE
  VIDEO
  STICKER
  // Кружочки (video_note) и обычное аудио (audio, отдельно от voice) — раньше
  // не были заведены вовсе: detectAttachment() в webhook/route.ts не проверял
  // message.video_note/message.audio, и такие сообщения приходили без
  // вложения вообще (терялся сам файл). Нужны для классификации вложений
  // ("Кружочки"/"Голосовые" во вкладке "Вложения" диалога).
  VIDEO_NOTE
  AUDIO
}

enum TelegramMessageStatus {
  RECEIVED
  PENDING
  SENT
  FAILED
}

// ============================================================
// МОНТАЖ — производственный workflow проекта монтажа, см. MontageProject.
// ============================================================

// Сокращено с исходных 14 значений до 5 понятных производственных этапов +
// CANCELLED (ТЗ "Упростить статусы монтажа", 2026-07-13): администратору не
// нужно различать "Готов к назначению"/"Назначен"/"В работе" — это один этап
// с точки зрения повседневной работы, разница видна по заполненным полям
// (editorId, startedAt), а не по отдельному статусу. Причины незаполненности
// (нет монтажёра/исходников/дедлайна) теперь отдельные предупреждения
// (см. MontageAttentionReason), не самостоятельные этапы производства.
// Старые значения (NEEDS_INFO/AWAITING_SOURCE/READY_FOR_ASSIGNMENT/ASSIGNED/
// AWAITING_REVISIONS/READY/ON_HOLD/ARCHIVED) перенесены в реальные данные
// скриптом scripts/migrate-montage-statuses/ (см. README.md рядом) и удалены
// из enum ПОСЛЕ подтверждённого dry-run + apply — на момент удаления в базе
// не осталось ни одной строки с этими значениями.
// ON_HOLD заменён на overlay-поля isPaused/pausedAt/pauseReason (тот же
// принцип, что Order.isArchived — статус НЕ меняется при паузе, см.
// MontageProject.isPaused). ARCHIVED заменён на isArchived/archivedAt (тоже
// overlay, как у Order). CANCELLED остаётся полноценным статусом (терминальный,
// не обратимый как пауза) — не входит в MONTAGE_STATUS_ORDER (не в основном
// выпадающем списке), устанавливается только явным действием "Отменить проект".
enum MontageStatus {
  NEW
  IN_PROGRESS
  IN_REVIEW
  REVISIONS
  DELIVERED
  CANCELLED
}

// Категория монтажа — структурированный список вместо свободного текста (ТЗ
// "Сделать «Тип контента» выпадающим списком"). OTHER + MontageProject.customContentType
// покрывает всё, что не укладывается в основные 5 категорий — исходный текст
// никогда не теряется (см. classifyMontageContentType, montage-model.ts).
enum MontageContentType {
  PODCAST
  SHORT_FORM
  TALKING_HEAD
  MOTION_DESIGN
  PRESENTATION
  OTHER
}

// Тип дней при задании планового срока количеством дней (не только календарных
// — ТЗ явно попросил различать рабочие/календарные, см. computeMontageDeadline).
enum MontageTurnaroundDayType {
  CALENDAR
  BUSINESS
}

// Оплата КЛИЕНТОМ студии за монтаж — независима от EditorPaymentStatus (см.
// ниже) и от MontageStatus: проект может быть "Сдан", но ещё не оплачен.
enum MontageClientPaymentStatus {
  NOT_SPECIFIED
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
  NOT_REQUIRED
}

// Выплата СТУДИЕЙ монтажёру/подрядчику — отдельный статус от оплаты клиента
// (см. комментарий выше и ТЗ п.3: "не считать проект оплаченным только
// потому, что он сдан").
enum MontageEditorPaymentStatus {
  NOT_CALCULATED
  PENDING
  PARTIALLY_PAID
  PAID
  NOT_REQUIRED
}

// Способ задания дедлайна — конкретная дата ИЛИ количество дней от даты
// поступления (turnaroundDays на MontageProject). deadlineDate всегда хранит
// итоговую рассчитанную дату независимо от способа — turnaroundDays хранится
// только чтобы не терять исходное "количество дней", если оно было выбрано
// (см. computeMontageDeadline, src/lib/montage-model.ts).
enum MontageDeadlineType {
  FIXED_DATE
  DURATION_DAYS
}

// ============================================================
// ПОЛЬЗОВАТЕЛИ (CMS)
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      Role     @default(OPERATOR)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clients                       Client[]               @relation("ResponsibleUser")
  notes                         ClientNote[]
  auditLogs                     AuditLog[]
  assignedTelegramConversations TelegramConversation[] @relation("AssignedAdmin")
  sentTelegramMessages          TelegramMessage[]
  telegramInternalNotes         TelegramInternalNote[]
  // Профессиональный профиль монтажёра — задел под будущий личный кабинет
  // (см. EditorProfile). Nullable/1:1: не у каждого User с role=EDITOR профиль
  // обязательно уже создан, и не у каждого EditorProfile обязательно есть
  // учётная запись (подрядчики без доступа к платформе).
  editorProfile                 EditorProfile?
  documentsCreated              Document[]             @relation("DocumentCreatedBy")
  documentsUpdated              Document[]             @relation("DocumentUpdatedBy")

  @@map("cms_user")
}

// ============================================================
// КЛИЕНТ
// ============================================================

model Client {
  id                   String              @id @default(cuid())
  name                 String
  firstName            String?             @map("first_name")
  lastName             String?             @map("last_name")
  patronymic           String?
  workplace            String?
  type                 ClientType          @default(INDIVIDUAL)
  status               ClientStatus        @default(NEW)
  source               ClientSource?
  customSource         String?             @map("custom_source")
  contactPerson        String?             @map("contact_person")
  phone                String?
  telegram             String?
  email                String?
  companyName          String?             @map("company_name")
  inn                  String?
  kpp                  String?
  ogrn                 String?
  legalAddress         String?             @map("legal_address")
  documentComment      String?             @map("document_comment")
  // Договорное состояние клиента — структурированное решение администратора
  // (не вычисляется автоматически из наличия Document type=CONTRACT), см.
  // ClientContractState. "Работа без договора" — осознанный вариант, а не
  // ошибка; создание Document type=CONTRACT переводит это поле в ACTIVE
  // (см. createDocument, src/lib/actions/documents.ts), дальше администратор
  // может менять его вручную.
  contractState        ClientContractState @default(UNSPECIFIED) @map("contract_state")
  contractStateComment String?             @map("contract_state_comment")
  contractPlannedDate  DateTime?           @map("contract_planned_date")
  notes                String?
  responsibleUserId    String?             @map("responsible_user_id")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  deletedAt            DateTime?           @map("deleted_at")

  responsibleUser       User?                  @relation("ResponsibleUser", fields: [responsibleUserId], references: [id])
  contacts              ClientContact[]
  clientNotes           ClientNote[]
  documents             Document[]
  visits                ClientVisit[]
  scheduleEvents        ScheduleEvent[]
  subscriptions         ClientSubscription[]
  orders                Order[]
  telegramConversations TelegramConversation[]
  // Только САМОСТОЯТЕЛЬНЫЕ проекты монтажа без исходного заказа (см.
  // MontageProject.clientId) — проекты монтажа, привязанные к заказу, здесь
  // не отображаются напрямую, их клиент читается через order.clientId
  // (getMontageProjectsForClient в src/lib/actions/montage.ts объединяет оба
  // случая одним запросом, не дублируя связь).
  montageProjects       MontageProject[]

  @@map("cms_client")
}

// ============================================================
// ИСТОРИЯ ВИЗИТОВ (импорт из таблиц студии)
// ============================================================

model ClientVisit {
  id            String    @id @default(cuid())
  clientId      String    @map("client_id")
  date          DateTime?
  // Время начала/конца съёмки — исторически не хранилось отдельно (только
  // календарный день в date + durationHours). Восстановлено из исходной
  // Google-таблицы (колонка вида "2 часа (16-18)") отдельным backfill-скриптом
  // для уже импортированных визитов; для новых импортов заполняется сразу
  // тем же парсером (см. extractTimeRange в src/lib/import/normalize.ts).
  // Nullable — у части старых визитов время в исходной строке не выделяется
  // однозначно и остаётся неизвестным, это ожидаемо, а не ошибка.
  startAt       DateTime? @map("start_at")
  endAt         DateTime? @map("end_at")
  room          String?
  format        String?
  durationHours Float?    @map("duration_hours")
  grossAmount   Float?    @map("gross_amount")
  netAmount     Float?    @map("net_amount")
  comment       String?
  importSource  String?   @map("import_source")
  importedAt    DateTime  @default(now()) @map("imported_at")
  // Хэш исходной строки Google-таблицы (дата+зал+формат+часы+суммы+комментарий) —
  // ключ для безопасной автосинхронизации: позволяет отличить уже загруженную
  // строку от новой без риска задвоить визит при повторном запуске.
  sourceRowHash String?   @unique @map("source_row_hash")
  // Заказ (Order), созданный "повышением" этого исторического визита до
  // полноценного заказа (см. scripts/promote-visits-to-orders) — проставляется
  // один раз в момент промоушена, дальше не меняется. Единственная цель —
  // идемпотентность самого промоушена: запрос "visit где orderId IS NULL"
  // находит только ещё не повышенные визиты, поэтому повторный запуск скрипта
  // не может задвоить заказ, даже если его прервали и перезапустили посередине.
  orderId       String?   @unique @map("order_id")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id])

  @@index([clientId])
  @@map("cms_client_visit")
}

// ============================================================
// ДОПОЛНИТЕЛЬНЫЕ КОНТАКТЫ
// ============================================================

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  name      String?
  role      String?
  phone     String?
  telegram  String?
  email     String?
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("cms_client_contact")
}

// ============================================================
// ВНУТРЕННИЕ ЗАМЕТКИ
// ============================================================

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  authorId  String?  @map("author_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorId], references: [id])

  @@map("cms_client_note")
}

// ============================================================
// ЖУРНАЛ ДЕЙСТВИЙ
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@map("cms_audit_log")
}

// ============================================================
// ДОКУМЕНТЫ — реестр номеров/статусов договоров, счетов и актов.
// НЕ файловое хранилище: платформа сознательно не хранит PDF, ссылки на
// файлы или интеграции с ЭДО/Диадок/Т-Бизнес/Я.Диском на этом этапе (см.
// AGENTS.md, "Реестр документов"). Документы пользователь продолжает вести
// вовне; здесь — только тип/номер/дата/статус/связи.
//
// Заменяет неиспользуемый стаб Document (0 строк в cms_document на момент
// замены, подтверждено прямым запросом перед миграцией — не файловая
// таблица ни разу не использовалась в коде с момента первого коммита).
// ============================================================

enum DocumentType {
  CONTRACT
  APPENDIX // приложение к договору — номер сквозной в рамках одного договора (contractId+number), не через DocumentCounter
  INVOICE
  ACT
}

// Общий enum на все три типа документа (тот же приём, что MontageStatus:
// значения размечены по типу комментарием, набор для конкретного UI-дропдауна
// сужается на уровне приложения — DOCUMENT_STATUS_OPTIONS_BY_TYPE в
// document-model.ts, а не отдельными enum'ами на каждый тип документа).
enum DocumentStatus {
  DRAFT // счёт: черновик
  ISSUED // счёт: выставлен
  NOT_PREPARED // акт: не подготовлен
  PREPARED // акт: подготовлен
  DELIVERED // акт: передан клиенту
  SIGNED // акт: подписан (ручная отметка реестра, не статус ЭДО)
  NEEDS_CORRECTION // акт: требует исправления
  ACTIVE // договор: действует
  ARCHIVED // договор/счёт/акт: архив
  CANCELLED // договор/счёт/акт: аннулирован
}

enum InvoicePurpose {
  ADVANCE
  FINAL_PAYMENT
  FULL_PAYMENT
  ADDITIONAL_SERVICE
  OTHER
}

model DocumentCounter {
  // "contract_number" | "document_package_number" — id счётчика, не Prisma id
  // в обычном смысле; строка используется как ключ, чтобы не заводить
  // отдельную модель на каждый вид сквозной нумерации (см. getNextCounterValue,
  // src/lib/actions/documents.ts). Атомарный upsert+increment безопасен под
  // конкурентными транзакциями за счёт row-level lock Postgres — тот же
  // эффект, что у обычного SEQUENCE, без сырого SQL.
  id    String @id
  value Int    @default(0)

  @@map("cms_document_counter")
}

model Document {
  id   String       @id @default(cuid())
  type DocumentType

  // Сквозной номер — только CONTRACT, из DocumentCounter("contract_number").
  number       Int?    @map("number")
  // "1"/"2" при нескольких счетах одной работы (аванс/окончательный) — только
  // INVOICE. Отображаемый номер собирается функцией getDocumentDisplayNumber
  // (document-model.ts) из parent.documentPackageNumber + suffix, само число
  // комплекта НЕ хранится здесь повторно (см. Order/MontageProject.documentPackageNumber
  // — единый источник, не копия).
  suffix       String? @map("suffix")
  // Номер указан администратором вручную при переносе исторических данных, а
  // не выдан DocumentCounter автоматически — влияет на то, как createDocument
  // подтягивает счётчик вверх (см. actions/documents.ts), и попадает в audit log.
  isHistorical Boolean @default(false) @map("is_historical")

  issueDate DateTime        @map("issue_date")
  status    DocumentStatus
  purpose   InvoicePurpose? @map("purpose")
  amount    Float?          @map("amount")
  dueDate   DateTime?       @map("due_date")
  comment   String?
  // Официальная формулировка услуги из документа (ручной ввод, копия текста
  // из настоящего договора/приложения/счёта/акта) — APPENDIX/INVOICE/ACT.
  // Тексты разных документов НЕ обязаны совпадать и не синхронизируются между
  // собой: UI предлагает одноразовое копирование при создании (см.
  // WorkDocumentsSection.tsx), после чего значения независимы.
  serviceDescription String? @map("service_description")

  clientId         String? @map("client_id") // обязателен для CONTRACT
  orderId          String? @map("order_id") // INVOICE/ACT к съёмке
  montageProjectId String? @map("montage_project_id") // INVOICE/ACT к монтажу
  contractId       String? @map("contract_id") // опц. ссылка INVOICE/ACT -> Document(CONTRACT) клиента

  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  archivedAt  DateTime? @map("archived_at")

  client         Client?         @relation(fields: [clientId], references: [id])
  order          Order?          @relation(fields: [orderId], references: [id])
  montageProject MontageProject? @relation(fields: [montageProjectId], references: [id])
  contract       Document?       @relation("ContractLink", fields: [contractId], references: [id])
  linkedDocs     Document[]      @relation("ContractLink")
  createdBy      User?           @relation("DocumentCreatedBy", fields: [createdById], references: [id])
  updatedBy      User?           @relation("DocumentUpdatedBy", fields: [updatedById], references: [id])

  @@unique([type, number])
  // Номер приложения уникален в рамках одного договора (CONTRACT никогда не
  // ссылается сам на себя через contractId, INVOICE/ACT не используют поле
  // number вообще — коллизий с @@unique([type, number]) договора нет).
  @@unique([contractId, number])
  @@index([clientId])
  @@index([orderId])
  @@index([montageProjectId])
  @@index([status])
  @@map("cms_document")
}

// ============================================================
// РАСПИСАНИЕ — АННОТАЦИИ К СОБЫТИЯМ GOOGLE КАЛЕНДАРЯ
// Google Calendar остаётся источником правды по названию/времени
// (сервис-аккаунт только на чтение). Здесь хранится только то, чего
// в календаре нет: зал, формат, камеры, цена, ссылки на материалы,
// статусы, привязка к клиенту.
// ============================================================

model ScheduleEvent {
  id                       String                   @id @default(cuid())
  calendarEventId          String?                  @unique @map("calendar_event_id")
  // Снэпшот для страницы Клиентов (блок неподтверждённых) — НЕ источник правды.
  // На странице Расписания эти поля всегда берутся из живого Google Calendar.
  title                    String?
  description              String?
  startAt                  DateTime?                @map("start_at")
  endAt                    DateTime?                @map("end_at")
  // Тип события: студийная запись / встреча / отсутствие сотрудника / служебная
  // пометка / прочее. Проверки материалов и оплаты применяются только к
  // STUDIO_BOOKING. Пока аннотации нет — тип определяется на лету по названию
  // события (classifyEventType), сюда он попадает только после первого
  // сохранения карточки (авто или вручную выбранный).
  eventType                EventType                @default(STUDIO_BOOKING) @map("event_type")
  clientId                 String?                  @map("client_id")
  clientNameRaw            String?                  @map("client_name_raw")
  contactRaw               String?                  @map("contact_raw")
  companyRaw               String?                  @map("company_raw")
  room                     String?
  format                   String?
  camerasCount             Int?                     @map("cameras_count")
  estimatedPrice           Float?                   @map("estimated_price")
  paymentMethod            PaymentMethod?           @map("payment_method")
  notes                    String?
  // Структурированная пометка акции (см. OrderPromotionType выше и
  // src/lib/promotion-model.ts) — источник правды по акции для записей с
  // уже существующей студийной записью, тот же принцип двойного источника,
  // что и у notes/Order.comment (см. toDTO в actions/orders.ts).
  promotionType            OrderPromotionType?      @map("promotion_type")
  // Предварительное бронирование студии для гримёра ПЕРЕД основной съёмкой —
  // отдельный интервал, не часть длительности/стоимости самой съёмки.
  // Источник правды — длительность в минутах; время начала гримёра всегда
  // пересчитывается от startAt (см. computeMakeupInterval, schedule-model.ts),
  // а не хранится отдельно, чтобы перенос съёмки не рассинхронизировал его.
  // null/0 — гримёр не предусмотрен.
  makeupDurationMinutes    Int?                     @map("makeup_duration_minutes")
  yandexDiskUrl            String?                  @map("yandex_disk_url")
  yandexDiskUrlAddedAt     DateTime?                @map("yandex_disk_url_added_at")
  yandexDiskUrlExpiresAt   DateTime?                @map("yandex_disk_url_expires_at")
  nasBackupUrl             String?                  @map("nas_backup_url")
  materialsComment         String?                  @map("materials_comment")
  materialsStatus          MaterialsStatus          @default(NO_LINKS) @map("materials_status")
  // Нужен ли монтаж после съёмки — null, пока администратор не решил (карточка
  // ещё не сохранялась с выбором); true/false после решения. Управляет
  // автопереводом связанного заказа в «Монтаж»/«Завершено», см. upsertScheduleEvent.
  editingRequired          Boolean?                 @map("editing_required")
  clientConfirmationStatus ClientConfirmationStatus @default(NOT_REQUIRED) @map("client_confirmation_status")
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")

  // Заказ (Order), из которого эта запись создана — только для записей,
  // созданных вручную через раздел "Заказы" без события Google Calendar
  // (calendarEventId в этом случае null). Записи, импортированные из живого
  // календаря, тоже могут иметь orderId — см. Order.googleEventId.
  orderId String? @unique @map("order_id")

  client            Client?            @relation(fields: [clientId], references: [id])
  order             Order?             @relation(fields: [orderId], references: [id])
  subscriptionUsage SubscriptionUsage?

  @@index([clientId])
  @@index([clientConfirmationStatus])
  @@index([startAt])
  @@index([eventType])
  @@map("cms_schedule_event")
}

// ============================================================
// ЗАКАЗЫ (CRM-воронка): Заявка → Записан в студию → Монтаж → Правки → Готово.
// Order — карточка воронки; при заполнении даты/времени записи к ней
// привязывается ScheduleEvent (см. ScheduleEvent.orderId) — та же модель,
// что используется для записей из Google Calendar ("Booking" из ТЗ).
// Google Calendar НЕ обновляется этой моделью ни при каких условиях — только
// импорт (googleEventId) в одну сторону, платформа в календарь не пишет.
// ============================================================

model Order {
  id                     String              @id @default(cuid())
  status                 OrderStatus         @default(LEAD)
  source                 OrderSource         @default(MANUAL)
  title                  String?
  clientId               String?             @map("client_id")
  // Снэпшот контактных данных на момент создания заказа — не источник правды,
  // если клиент привязан (clientId): тогда актуальные данные берутся из Client.
  // Хранится и для непривязанных заявок, и как история для привязанных.
  clientName             String?             @map("client_name")
  clientPhone            String?             @map("client_phone")
  clientTelegram         String?             @map("client_telegram")
  clientEmail            String?             @map("client_email")
  clientType             ClientType?         @map("client_type")
  companyName            String?             @map("company_name")
  serviceType            String?             @map("service_type")
  room                   String?
  plannedStartTime       DateTime?           @map("planned_start_time")
  plannedEndTime         DateTime?           @map("planned_end_time")
  durationMinutes        Int?                @map("duration_minutes")
  preliminaryAmount      Float?              @map("preliminary_amount")
  paymentStatus          OrderPaymentStatus  @default(NOT_SPECIFIED) @map("payment_status")
  paymentMethod          PaymentMethod?      @map("payment_method")
  comment                String?
  // Структурированная пометка акции (см. OrderPromotionType и
  // src/lib/promotion-model.ts) — заявок без своей записи в расписании
  // (LEAD без даты) касается напрямую; для заказов с записью источник
  // правды — ScheduleEvent.promotionType, тот же принцип, что и у comment/notes.
  promotionType          OrderPromotionType? @map("promotion_type")
  // Событие Google Calendar, из которого создан заказ (только source=GOOGLE_CALENDAR).
  // Используется для защиты от дублей при повторном импорте/сохранении события.
  googleEventId          String?             @unique @map("google_event_id")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  completedAt            DateTime?           @map("completed_at")
  // Момент перевода в CANCELLED ("Отказ") — тот же принцип, что у completedAt
  // выше: выставляется один раз в updateOrderStatus и больше не трогается,
  // даже если заказ потом вернули из "Отказа" в другой статус.
  rejectedAt             DateTime?           @map("rejected_at")
  // Момент последней смены status (не путать с updatedAt — тот меняется при
  // любом редактировании заказа). Используется для сортировки карточек внутри
  // колонок канбана "по недавности изменения статуса". Обновляется явно в
  // updateOrderStatus/updateOrder — см. src/lib/actions/orders.ts.
  statusUpdatedAt        DateTime            @default(now()) @map("status_updated_at")
  // ---- Архив (см. src/lib/order-model.ts: isOrderReadyForArchive,
  // ORDER_ARCHIVE_AFTER_DAYS) — статус COMPLETED/CANCELLED остаётся финальным
  // навсегда, isArchived лишь скрывает старую (>7 дней) карточку из основной
  // CRM-воронки в отдельный экран. Не путать со старым OrderStatus.ARCHIVED,
  // которому никогда ничего не присваивается.
  isArchived             Boolean             @default(false) @map("is_archived")
  archivedAt             DateTime?           @map("archived_at")
  archiveReason          ArchiveReason?      @map("archive_reason")
  // Момент ручного "Вернуть из архива" — пока он позже statusUpdatedAt,
  // автосвип (archiveEligibleOrders) не трогает заказ повторно, даже если
  // completedAt/rejectedAt всё ещё старше 7 дней. Как только статус реально
  // меняется ещё раз, statusUpdatedAt обгоняет эту метку и заказ снова
  // становится кандидатом на архивацию по обычному правилу.
  manuallyUnarchivedAt   DateTime?           @map("manually_unarchived_at")
  // Telegram-диалог, из переписки которого создан заказ (кнопка "Создать
  // заказ из переписки") — тот же принцип, что и googleEventId выше: поле,
  // отслеживающее источник, живёт на Order, а не на самом источнике.
  telegramConversationId String?             @unique @map("telegram_conversation_id")
  // Требуется ли для заказа договор/счёт/акт и в каком составе — см.
  // DocumentFlowType. Только предлагается при создании (suggestDocumentFlowType,
  // document-model.ts) по типу клиента и способу оплаты, дальше это ручной
  // выбор администратора, не тихий автоматический вывод (см. AGENTS.md).
  documentFlowType       DocumentFlowType    @default(UNKNOWN) @map("document_flow_type")
  // Сквозной номер комплекта документов ЭТОЙ работы ("Счёт №127-1/127-2,
  // Акт №127") — назначается один раз при создании первого счёта/акта заказа
  // (см. createDocument, actions/documents.ts). Живёт на Order, а не на каждом
  // Document, чтобы несколько документов одной работы не хранили одно и то же
  // число копией (см. AGENTS.md, "Реестр документов").
  documentPackageNumber  Int?                @unique @map("document_package_number")

  client               Client?               @relation(fields: [clientId], references: [id])
  scheduleEvent        ScheduleEvent?
  telegramConversation TelegramConversation? @relation(fields: [telegramConversationId], references: [id])
  documents            Document[]
  // Исторический визит (ClientVisit), из которого этот заказ был создан
  // "повышением" при восстановлении истории студии — null для всех обычных
  // заказов (ручных, из календаря, из Telegram). См. ClientVisit.orderId.
  visit                ClientVisit?
  // Проект(ы) монтажа, созданные по этому заказу — массив (не 1:1), чтобы не
  // блокировать будущую возможность нескольких продуктов монтажа из одной
  // съёмки (см. MontageProject.orderId и комментарий в ГЛАВНОЙ КОНЦЕПЦИИ ТЗ).
  // В v1 автосоздание (ensureMontageProjectForOrder, src/lib/actions/montage.ts)
  // гарантирует не больше одной АВТОМАТИЧЕСКИ созданной записи на заказ.
  montageProjects      MontageProject[]

  @@index([clientId])
  @@index([status])
  @@index([isArchived])
  @@map("cms_order")
}

// ============================================================
// TELEGRAM — входящие заявки клиентов через Telegram-бота студии.
// MVP: только личные диалоги (chatType = PRIVATE). Групповые рабочие чаты
// (chatType GROUP/SUPERGROUP) поддержаны на уровне схемы заранее, но логика
// их чтения/различения клиент-vs-сотрудник добавится отдельным этапом позже.
// ============================================================

model TelegramConversation {
  id                String                     @id @default(cuid())
  // Строка, а не Int: chat_id супергрупп у Telegram выходит за пределы
  // диапазона обычного 32-битного целого.
  telegramChatId    String                     @unique @map("telegram_chat_id")
  chatType          TelegramChatType           @map("chat_type")
  telegramUserId    String?                    @map("telegram_user_id") // только для private
  telegramUsername  String?                    @map("telegram_username") // только для private
  groupTitle        String?                    @map("group_title") // только для group/supergroup, не используется в MVP
  // Имя/фамилия из профиля Telegram — подсказка для сопоставления с Client,
  // не источник правды (в отличие от Client.name после ручной привязки).
  clientNameGuess   String?                    @map("client_name_guess")
  // Раздельные first_name/last_name из Telegram (в отличие от clientNameGuess,
  // который их сразу склеивает) — нужны, чтобы форма создания клиента могла
  // предзаполнить поля "Имя"/"Фамилия" по отдельности, а не одной строкой.
  // Заполняются только при первом сообщении (как и clientNameGuess), не
  // обновляются на каждое новое сообщение.
  telegramFirstName String?                    @map("telegram_first_name")
  telegramLastName  String?                    @map("telegram_last_name")
  phone             String? // если клиент сам написал номер в чат
  linkedClientId    String?                    @map("linked_client_id")
  status            TelegramConversationStatus @default(NEW)
  lastMessageAt     DateTime?                  @map("last_message_at")
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @updatedAt @map("updated_at")

  // ---- Consent-first (обязательно до подключения администратора) ----
  consentStatus           TelegramConsentStatus @default(NONE) @map("consent_status")
  // Момент отправки запроса согласия для consentRequestVersion — чтобы не
  // слать его повторно на каждое новое сообщение клиента.
  consentRequestSentAt    DateTime?             @map("consent_request_sent_at")
  consentRequestVersion   String?               @map("consent_request_version")
  // Telegram message_id сообщения с кнопкой «Согласиться» — нужен, чтобы
  // после нажатия убрать inline-кнопку из ЭТОГО конкретного сообщения через
  // editMessageReplyMarkup (иначе кнопка в Telegram-клиенте у клиента
  // остаётся кликабельной и после согласия).
  consentRequestMessageId String?               @map("consent_request_message_id")

  // ---- Рабочие поля инбокса ----
  assignedAdminId  String?   @map("assigned_admin_id") // информационная метка "кто ведёт", не ограничение видимости
  unreadCount      Int       @default(0) @map("unread_count")
  isPinned         Boolean   @default(false) @map("is_pinned")
  archivedAt       DateTime? @map("archived_at")
  // Первое сообщение клиента — подсказка для предзаполнения комментария заказа.
  firstMessageText String?   @map("first_message_text")

  linkedClient  Client?                @relation(fields: [linkedClientId], references: [id])
  assignedAdmin User?                  @relation("AssignedAdmin", fields: [assignedAdminId], references: [id])
  messages      TelegramMessage[]
  consents      TelegramConsent[]
  internalNotes TelegramInternalNote[]
  order         Order? // обратная связь от Order.telegramConversationId

  @@index([linkedClientId])
  @@index([status])
  @@index([assignedAdminId])
  @@map("cms_telegram_conversation")
}

model TelegramMessage {
  id                String                   @id @default(cuid())
  conversationId    String                   @map("conversation_id")
  // update_id — для идемпотентности на уровне всего update (в т.ч.
  // callback_query, у которого нет message_id в привычном смысле).
  telegramUpdateId  String?                  @map("telegram_update_id")
  // message_id у Telegram уникален только В РАМКАХ чата, не глобально —
  // поэтому дедуп ниже строится по паре (conversationId, telegramMessageId).
  telegramMessageId String                   @map("telegram_message_id")
  direction         TelegramMessageDirection
  // Кто фактически автор — клиент / администратор / бот (авто-сообщения
  // согласия) / системное событие. senderTelegramId/Username/Name заполнены
  // только когда senderType = CLIENT.
  // Дефолт CLIENT безопасен для миграции: все существующие строки на момент
  // добавления этого поля — реальные входящие сообщения от клиента.
  senderType        TelegramSenderType       @default(CLIENT) @map("sender_type")
  senderAdminId     String?                  @map("sender_admin_id") // если senderType = ADMIN
  senderTelegramId  String?                  @map("sender_telegram_id")
  senderUsername    String?                  @map("sender_username")
  senderName        String?                  @map("sender_name")
  text              String?
  messageType       TelegramMessageType      @default(TEXT) @map("message_type")
  status            TelegramMessageStatus    @default(RECEIVED)
  errorMessage      String?                  @map("error_message")
  sentAt            DateTime?                @map("sent_at")
  rawPayload        Json                     @map("raw_payload")
  createdAt         DateTime                 @default(now()) @map("created_at")

  conversation TelegramConversation       @relation(fields: [conversationId], references: [id])
  senderAdmin  User?                      @relation(fields: [senderAdminId], references: [id])
  attachment   TelegramMessageAttachment?

  // Защита от дублей при повторной доставке update от Telegram.
  @@unique([conversationId, telegramMessageId])
  @@index([conversationId])
  @@map("cms_telegram_message")
}

// Файл не хранится у нас — только telegramFileId, сам файл при каждом
// просмотре запрашивается у Telegram заново через getFile и проксируется
// через src/app/api/telegram/file/[attachmentId]/route.ts (в проекте нет
// S3/Object Storage, решение принято сознательно, см. память проекта).
// 1:1 с TelegramMessage — Telegram-альбомы (несколько фото одним сообщением)
// вне MVP.
model TelegramMessageAttachment {
  id                   String   @id @default(cuid())
  messageId            String   @unique @map("message_id")
  telegramFileId       String   @map("telegram_file_id")
  telegramFileUniqueId String?  @map("telegram_file_unique_id")
  fileName             String?  @map("file_name")
  mimeType             String?  @map("mime_type")
  fileSize             Int?     @map("file_size")
  duration             Int? // voice/video, секунды
  width                Int?
  height               Int?
  // Статичный стикер (обычный webp) рендерится картинкой; анимированный
  // (tgs/webm) — просто плашкой в UI, без Lottie/webm-плеера.
  isAnimatedSticker    Boolean  @default(false) @map("is_animated_sticker")
  createdAt            DateTime @default(now()) @map("created_at")

  message TelegramMessage @relation(fields: [messageId], references: [id])

  @@map("cms_telegram_message_attachment")
}

// Факт согласия/отзыва — отдельная таблица (не просто поле на диалоге),
// т.к. согласие юридически значимо и должно быть неизменяемой записью:
// conversation.consentStatus — это "текущее состояние", а TelegramConsent —
// история того, когда и на какой именно текст согласия клиент нажал.
model TelegramConsent {
  id                String    @id @default(cuid())
  conversationId    String    @map("conversation_id")
  telegramUserId    String?   @map("telegram_user_id")
  telegramChatId    String    @map("telegram_chat_id")
  username          String?
  displayName       String?   @map("display_name")
  consentVersion    String    @map("consent_version")
  consentText       String    @map("consent_text")
  policyUrl         String?   @map("policy_url")
  // 'given' | 'revoked' — обычная строка, не enum: новая версия текста
  // согласия не должна требовать миграции типа.
  status            String
  givenAt           DateTime? @map("given_at")
  revokedAt         DateTime? @map("revoked_at")
  source            String    @default("telegram_bot")
  telegramMessageId String?   @map("telegram_message_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  conversation TelegramConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@map("cms_telegram_consent")
}

// Внутренние заметки по диалогу — видны только сотрудникам, никогда не
// уходят клиенту (в отличие от TelegramMessage, которая всегда про переписку).
model TelegramInternalNote {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  authorUserId   String   @map("author_user_id")
  text           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  conversation TelegramConversation @relation(fields: [conversationId], references: [id])
  author       User                 @relation(fields: [authorUserId], references: [id])

  @@index([conversationId])
  @@map("cms_telegram_internal_note")
}

// Единственная строка-синглтон настроек модуля (id всегда "singleton") —
// одна конфигурация на всё приложение, не per-user. Токен бота НЕ хранится
// здесь — только в TELEGRAM_BOT_TOKEN (env), чтобы никогда не попасть на
// фронтенд даже случайно через сериализацию этой модели.
model TelegramSettings {
  id                               String   @id @default("singleton")
  privacyPolicyUrl                 String?  @map("privacy_policy_url")
  consentRequired                  Boolean  @default(true) @map("consent_required")
  consentText                      String   @map("consent_text")
  consentVersion                   String   @default("v1") @map("consent_version")
  managerHandoffMessage            String   @default("Спасибо! Согласие получено. Администратор скоро подключится к диалогу.") @map("manager_handoff_message")
  dataRetentionMode                String   @default("archive_forever") @map("data_retention_mode")
  dataRetentionDays                Int?     @map("data_retention_days")
  archiveWarningThresholdMessages  Int      @default(5000) @map("archive_warning_threshold_messages")
  archiveWarningThresholdStorageMb Int      @default(1000) @map("archive_warning_threshold_storage_mb")
  // Используется начиная с Этапа B (вложения) — задел на будущее, значение
  // по умолчанию пустое, ни на что не влияет до появления вложений.
  allowedAttachmentTypes           Json     @default("[]") @map("allowed_attachment_types")
  maxAttachmentSizeMb              Int      @default(20) @map("max_attachment_size_mb")
  updatedAt                        DateTime @updatedAt @map("updated_at")

  @@map("cms_telegram_settings")
}

// ============================================================
// АБОНЕМЕНТЫ КЛИЕНТОВ — покупка пакета часов записи (6/10/20),
// списываемых по отдельным записям расписания (ScheduleEvent).
// Оплата абонемента (paidAmount) фиксируется один раз при покупке —
// отдельные записи, списывающие из него часы, не создают повторную выручку.
// ============================================================

model ClientSubscription {
  id                 String             @id @default(cuid())
  clientId           String             @map("client_id")
  packageHours       Float              @map("package_hours")
  // Часы, использованные ДО того, как эту запись начали привязывать к событиям
  // расписания (например, реконструированные из старых заметок в Google-таблице,
  // где известен только текущий остаток, а не список сессий). Реальный расход
  // считается как openingUsedHours + сумма SubscriptionUsage.usedHours — так
  // packageHours всегда остаётся исходным размером пакета, а не "тем, что осталось".
  openingUsedHours   Float              @default(0) @map("opening_used_hours")
  paidAmount         Float?             @map("paid_amount")
  purchasedAt        DateTime           @default(now()) @map("purchased_at")
  status             SubscriptionStatus @default(ACTIVE)
  // Момент последней смены status — параллель Order.statusUpdatedAt. Меняется
  // и автопереходами ACTIVE⇄USED_UP (списание/возврат часов), и ручными
  // действиями ниже — единственный источник правды здесь и там, и там —
  // updateSubscriptionStatus/chargeEventToSubscription (src/lib/actions/subscriptions.ts).
  statusUpdatedAt    DateTime           @default(now()) @map("status_updated_at")
  // ---- Даты переходов в каждый терминальный статус — по одному разу
  // (сохраняются при первом переходе, дальше не трогаются даже если статус
  // потом меняют ещё раз вручную) ----
  usedAt             DateTime?          @map("used_at")
  cancelledAt        DateTime?          @map("cancelled_at")
  refundedAt         DateTime?          @map("refunded_at")
  cancellationReason String?            @map("cancellation_reason")
  refundAmount       Float?             @map("refund_amount")
  refundReason       String?            @map("refund_reason")
  // Комментарий администратора — не привязан к конкретному статусу, можно
  // оставить/обновить при любом ручном действии (см. updateSubscriptionStatus).
  adminComment       String?            @map("admin_comment")
  // ---- Архив — оверлей ПОВЕРХ status, не замена ему (тот же принцип, что у
  // Order.isArchived): архивный абонемент сохраняет свой реальный статус
  // (used/cancelled/refunded/даже active), просто скрыт из активных списков и
  // недоступен для выбора в заказе. ----
  isArchived         Boolean            @default(false) @map("is_archived")
  archivedAt         DateTime?          @map("archived_at")
  notes              String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  client Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  usages SubscriptionUsage[]

  @@index([clientId])
  @@index([status])
  @@index([isArchived])
  @@map("cms_client_subscription")
}

// Списание часов по одной записи расписания. У события может быть максимум
// одно списание (@@unique) — при смене абонемента/пересохранении старая
// строка заменяется, а не накапливается.
model SubscriptionUsage {
  id              String   @id @default(cuid())
  subscriptionId  String   @map("subscription_id")
  scheduleEventId String   @unique @map("schedule_event_id")
  usedHours       Float    @map("used_hours")
  usedAt          DateTime @default(now()) @map("used_at")
  // Комментарий к конкретному списанию — заполняется вручную при переносе
  // оплаты между абонементами или ручной корректировке (см. Часть 4 ТЗ).
  comment         String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  subscription  ClientSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  scheduleEvent ScheduleEvent      @relation(fields: [scheduleEventId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("cms_subscription_usage")
}

// ============================================================
// РАСХОДЫ СТУДИИ (импорт из Google-таблицы "Расходы" + ручное добавление в будущем)
// ============================================================

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  expenses  Expense[]

  @@map("cms_expense_category")
}

// Один расход/обязательство. plannedAmount — полная стоимость покупки/услуги,
// actualAmount — сколько из неё реально оплачено на сегодня (может расти со
// временем по мере частичных оплат одного и того же обязательства). Остаток,
// процент оплаты и статус план/факт считаются на лету в actions-слое, а не
// хранятся здесь — так же, как остаток часов абонемента не хранится в БД,
// чтобы не рассинхронизироваться при пересчёте.
model Expense {
  id             String    @id @default(cuid())
  externalSource String    @default("google_sheets") @map("external_source")
  // Стабильный идентификатор строки таблицы — хэш от даты+названия+категории+
  // плановой суммы (полей, которые НЕ меняются при частичной оплате). Позволяет
  // при повторной синхронизации ОБНОВИТЬ существующий расход (если увеличилась
  // фактическая оплата), а не создать дубликат. Ручные расходы (без импорта) —
  // без внешнего идентификатора.
  externalId     String?   @unique @map("external_id")
  date           DateTime?
  title          String
  categoryId     String?   @map("category_id")
  plannedAmount  Float?    @map("planned_amount")
  actualAmount   Float?    @map("actual_amount")
  // Статус как он записан в таблице ("Получен"/"Заказан" и т.д.) — хранится как
  // свободный текст, без строгого enum, потому что реальные данные содержат
  // нестандартные значения (например, для позиций-пожеланий на оборудование).
  rawStatus      String?   @map("raw_status")
  orderedBy      String?   @map("ordered_by")
  paidBy         String?   @map("paid_by")
  receivedBy     String?   @map("received_by")
  comment        String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  category ExpenseCategory? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([date])
  @@map("cms_expense")
}

// ============================================================
// МОНТАЖЁРЫ — профессиональный профиль, отдельный от User (см. Role.EDITOR):
// не у каждого монтажёра/подрядчика есть учётная запись платформы, и не
// каждый User с ролью EDITOR обязательно уже оформлен как монтажёр (задел
// под будущий личный кабинет — см. userId ниже).
// ============================================================

model EditorProfile {
  id             String   @id @default(cuid())
  // Учётная запись платформы этого монтажёра, если уже создана — nullable,
  // т.к. подрядчики без доступа к платформе тоже должны попадать в базу
  // монтажёров (см. ТЗ п.8). @unique — один User не может быть двумя профилями.
  userId         String?  @unique @map("user_id")
  firstName      String?  @map("first_name")
  lastName       String?  @map("last_name")
  // Единственное обязательное имя-поле — то, что реально показывается везде
  // (списки, карточки проектов, канбан). firstName/lastName — опциональная
  // структура поверх него (для будущей карточки монтажёра/личного кабинета),
  // не источник правды для отображения.
  displayName    String   @map("display_name")
  phone          String?
  telegram       String?
  email          String?
  specialization String?
  notes          String?
  // Единственный флаг "виден ли монтажёр как активный" — отдельного enum
  // "статус" не заводим (ТЗ предупреждал не плодить поля вслепую: status и
  // active в черновом списке ТЗ дублировали бы друг друга без второго
  // самостоятельного смысла).
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user     User?            @relation(fields: [userId], references: [id])
  projects MontageProject[]

  @@map("cms_editor_profile")
}

// ============================================================
// ПРОЕКТ МОНТАЖА — отдельная сущность от Order (см. ГЛАВНУЮ КОНЦЕПЦИЮ ТЗ):
// связан с исходным заказом (orderId) для проектов, созданных из съёмки
// студии, либо самостоятелен (orderId = null, clientId — собственный).
// Клиент/компания/данные съёмки для orderId-проектов НЕ дублируются —
// читаются через order.client/order.scheduleEvent на уровне DTO
// (src/lib/actions/montage.ts), та же дисциплина, что и у OrderDTO.
// ============================================================

model MontageProject {
  id                String              @id @default(cuid())
  // Не @unique: намеренно допускает в будущем несколько проектов монтажа на
  // один заказ (см. комментарий у Order.montageProjects). Идемпотентность
  // АВТОМАТИЧЕСКОГО создания (одно из ТЗ п.6: "не создаётся повторно при
  // каждом сохранении заказа") обеспечивается в коде (ensureMontageProjectForOrder),
  // а не ограничением схемы, ручное добавление второго проекта остаётся возможным.
  orderId           String?             @map("order_id")
  // Только для САМОСТОЯТЕЛЬНЫХ проектов (orderId = null) — см. Client.montageProjects.
  // Для проектов, привязанных к заказу, клиент читается через order.clientId,
  // это поле у них остаётся null (не дублируем).
  clientId          String?             @map("client_id")
  // Снэпшот имени заказчика "как в источнике" — тот же принцип, что
  // Order.clientName: заполняется всегда (в т.ч. когда clientId уже задан),
  // но служит источником отображения ТОЛЬКО пока clientId = null (см.
  // getMontageAttentionReasons/'NO_CLIENT_LINK', montage-model.ts). Нужно для
  // исторического импорта (scripts/import-montage-projects) — часть строк
  // Google-таблицы не удаётся однозначно сопоставить ни с одним Client
  // (например, "Наталия и Нина" при реальном клиенте "Наталия Богданова и
  // Нина" — неоднозначно, не связываем автоматически), но терять сами
  // данные проекта из-за этого не нужно: администратор довяжет клиента
  // вручную позже, а до этого видит исходное имя и пометку "!".
  clientName        String?             @map("client_name")
  title             String?
  description       String?
  // Структурированная категория (см. MontageContentType выше) — было свободным
  // текстом, переведено в enum задним числом: все 76 исторических проектов
  // классифицированы скриптом scripts/migrate-montage-statuses по названию
  // (см. classifyMontageContentType, montage-model.ts), ни один текст не
  // потерян — то, что не удалось уверенно классифицировать, ушло в OTHER
  // с оригинальным текстом в customContentType ниже.
  contentType       MontageContentType? @map("content_type")
  // Ручное уточнение, когда contentType = OTHER — показывается только тогда
  // в UI (см. ТЗ: "Не хранить пользовательское значение вместо enum").
  customContentType String?             @map("custom_content_type")
  status            MontageStatus       @default(NEW)

  // ---- Служебные состояния — НЕ часть основного производственного статуса
  // (ТЗ "Отдельные служебные состояния"): overlay поверх status, тем же
  // принципом, что Order.isArchived. ----
  // Пауза обратима (isPaused переключается туда-обратно), поэтому pausedAt/
  // pauseReason НЕ очищаются при снятии паузы — остаются историей последней
  // паузы, тот же принцип, что у одноразовых меток статуса заказа
  // (Order.completedAt и т.п.: пишутся один раз, не стираются задним числом).
  isPaused     Boolean   @default(false) @map("is_paused")
  pausedAt     DateTime? @map("paused_at")
  pauseReason  String?   @map("pause_reason")
  // Отмена — терминальная, необратимого действия ("Отменить проект"),
  // поэтому, в отличие от паузы, это реальный статус (status = CANCELLED),
  // а cancelledAt/cancelReason — только сопутствующие детали момента отмены.
  cancelledAt  DateTime? @map("cancelled_at")
  cancelReason String?   @map("cancel_reason")
  // Архивация — отдельное действие ПОСЛЕ Сдан/Отменён (ТЗ "Архивация —
  // отдельное действие"), тот же overlay-принцип, что Order.isArchived;
  // archivedAt уже существовал в схеме (ниже), isArchived добавлен, чтобы
  // явно фильтровать "архивный / не архивный", а не полагаться на naличие даты.
  isArchived   Boolean   @default(false) @map("is_archived")

  editorId            String?   @map("editor_id")
  // Дополнительные исполнители — простой список id EditorProfile без ролей
  // (озвучка/моушен и т.п. из ТЗ п.26 сознательно не заведены отдельно: "не
  // усложнять интерфейс без необходимости", в карточке один основной
  // ответственный + этот список).
  additionalEditorIds String[]  @map("additional_editor_ids")
  assignedAt          DateTime? @map("assigned_at")

  sourceReceivedAt  DateTime?                 @map("source_received_at")
  startedAt         DateTime?                 @map("started_at")
  // Способ задания срока и сам срок — см. MontageDeadlineType выше.
  deadlineType      MontageDeadlineType?      @map("deadline_type")
  // Итоговая рассчитанная дата дедлайна независимо от deadlineType — единый
  // helper computeMontageDeadline (src/lib/montage-model.ts) пересчитывает её
  // при сохранении, здесь всегда хранится готовое значение для сортировки/
  // фильтров/просрочки без пересчёта на каждом чтении.
  deadlineDate      DateTime?                 @map("deadline_date")
  // Исходное "количество дней", если выбран этот способ — хранится отдельно от
  // deadlineDate (см. ТЗ п.19: "не хранить только строку «10 дней»"), чтобы при
  // повторном открытии карточки показать именно то число, которое ввели.
  turnaroundDays    Int?                      @map("turnaround_days")
  // Календарные или рабочие дни — влияет на то, как turnaroundDays превращается
  // в deadlineDate (см. computeMontageDeadline, montage-model.ts: рабочие дни
  // пропускают субботу/воскресенье, без учёта праздников — календаря
  // праздников в проекте нет и заводить его ради одного поля преждевременно).
  turnaroundDayType MontageTurnaroundDayType? @map("turnaround_day_type")
  // Технический момент перехода в "Сдан" — заполняется СЕРВЕРОМ автоматически
  // при смене статуса (см. actions/montage.ts), больше не отдельное поле формы
  // (ТЗ "Убрать путаницу с датой завершения работы": администратор видит и
  // редактирует только 4 понятных поля срока — deliveredAt среди них
  // "фактическая дата сдачи клиенту", а completedAt — внутренняя метка для
  // аналитики, не показывается как отдельный ввод).
  completedAt       DateTime?                 @map("completed_at")
  // Фактическая дата сдачи материала клиенту — единственное "факт"-поле среди
  // видимых в форме, сравнивается с deadlineDate через montageDeadlineLabel
  // (montage-model.ts) для "сдано вовремя/с опозданием".
  deliveredAt       DateTime?                 @map("delivered_at")

  // ---- Финансы: два независимых источника суммы, прибыль считается, а не
  // хранится (см. computeMontageProfit, src/lib/montage-model.ts) ----
  clientAmount        Float?                     @map("client_amount")
  editorAmount        Float?                     @map("editor_amount")
  clientPaymentStatus MontageClientPaymentStatus @default(NOT_SPECIFIED) @map("client_payment_status")
  editorPaymentStatus MontageEditorPaymentStatus @default(NOT_CALCULATED) @map("editor_payment_status")
  clientPaidAt        DateTime?                  @map("client_paid_at")
  editorPaidAt        DateTime?                  @map("editor_paid_at")
  paymentComment      String?                    @map("payment_comment")

  // ---- Материалы: исходники и финальный результат — разные поля (ТЗ п.21:
  // "не использовать ссылку исходников как ссылку на финальный монтаж").
  // sourceMaterialsUrl — только ПЕРЕОПРЕДЕЛЕНИЕ для проектов, у которых нет
  // связанного заказа/записи или нужна другая ссылка; для обычных
  // orderId-проектов исходники по умолчанию читаются из
  // order.scheduleEvent.yandexDiskUrl (см. getMontageSourceMaterialsUrl,
  // src/lib/montage-model.ts) — не дублируем существующее поле. ----
  sourceMaterialsUrl    String? @map("source_materials_url")
  // Отдельное, специально NAS-поле — сознательно НЕ то же самое, что
  // sourceMaterialsUrl выше. sourceMaterialsUrl/effectiveSourceMaterialsUrl —
  // это "чем сейчас реально пользуется монтажёр" (обычно Яндекс.Диск, ссылка
  // истекает через 14 дней, см. YANDEX_LINK_EXPIRY_DAYS в schedule-model.ts),
  // а sourceMaterialsNasUrl — это отдельный, более строгий вопрос "исходники
  // сохранены на постоянное хранение NAS" (ТЗ контроля материалов: "не считать
  // ссылку на Яндекс.Диск заменой обязательному хранению на NAS"). Оба поля
  // независимы и оба видны в карточке — не переиспользуем/не переименовываем
  // существующее поле, чтобы не менять его текущее поведение и потребителей.
  sourceMaterialsNasUrl String? @map("source_materials_nas_url")
  mountedMaterialNasUrl String? @map("mounted_material_nas_url")
  deliveryUrl           String? @map("delivery_url")
  materialsComment      String? @map("materials_comment")

  // ---- Правки ----
  revisionsIncluded Int?    @map("revisions_included")
  revisionsUsed     Int     @default(0) @map("revisions_used")
  revisionsComment  String? @map("revisions_comment")

  requirements    String?
  internalComment String? @map("internal_comment")
  clientComment   String? @map("client_comment")

  // ---- Импорт из исторической Google-таблицы (см. scripts/import-montage-projects) ----
  importSource     String? @map("import_source")
  // Fingerprint строки исходной таблицы — тот же принцип, что ClientVisit.sourceRowHash
  // и Expense.externalId: гарантирует, что повторный запуск импорта обновит, а
  // не задвоит проект.
  importExternalId String? @unique @map("import_external_id")

  // ---- Реестр документов (см. AGENTS.md, "Реестр документов") ----
  // Независимое поле, НЕ связанное с финансовым revenueRecognitionMode —
  // такого механизма в проекте нет (сознательно не заводился при интеграции
  // Монтажа с Финансами в этой же сессии, т.к. риска задвоения выручки не
  // было). documentMode описывает только то, как оформляются документы
  // монтажа: включены в комплект заказа или у монтажа свои счёт/акт.
  documentMode          MontageDocumentMode @default(UNKNOWN) @map("document_mode")
  // Номер комплекта — только для SEPARATE-проектов (см. Order.documentPackageNumber,
  // тот же принцип: живёт на работе, не копируется в каждый Document).
  documentPackageNumber Int?                @unique @map("document_package_number")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  archivedAt DateTime? @map("archived_at")

  order     Order?         @relation(fields: [orderId], references: [id])
  client    Client?        @relation(fields: [clientId], references: [id])
  editor    EditorProfile? @relation(fields: [editorId], references: [id])
  documents Document[]

  @@index([orderId])
  @@index([clientId])
  @@index([editorId])
  @@index([status])
  @@index([deadlineDate])
  @@map("cms_montage_project")
}

// Как оформляются документы проекта монтажа — см. MontageProject.documentMode.
enum MontageDocumentMode {
  INCLUDED_IN_ORDER
  SEPARATE
  NOT_REQUIRED
  UNKNOWN
}
